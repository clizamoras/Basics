class Solution:
    def matrix(self,num):
        rows=len(num)
        cols=len(num[0])
        s=[]
        for i in range(rows):
            for j in range (cols):
                if num[i][j]==0:
                    s.append((i,j))
        for i,j in s:
            for k in range(rows):
                num[k][j]=0
            for k in range(cols):
                num[i][k]=0
        return num

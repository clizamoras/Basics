class Solution:
    def pascal(self,n,s,e):
        if s>e:
            return 
        n[s],n[e]=n[e],n[s]
 
        self.pascal(n,s+1,e-1)
        
obj=Solution()
n=[1,2,3,4,5]
print(obj.pascal(n,0,4))
print(n)

class Solution:
    def roman(self,s):
        n=len(s)
        roman={'I':1, 'V' : 5, 'X' : 10, 'L' : 50, 'C' : 100, 'D' : 500, 'M': 1000}
        r=0
        for i in range(n-1):
            if roman[s[i]]>=roman[s[i+1]]:
                r+=roman[s[i]]
            else:
                r-=roman[s[i]]
        r+=roman[s[n-1]]
        return r
s="LVIII"
obj=Solution()
print(obj.roman(s))

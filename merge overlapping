class Solution:
 def merge(self,num):
   num.sort()
   r=[]
   for i in num:
     if r===[]:
       r.append(i)
     else:
       last=r[-1]
       if i[0]<=last[1]:
         last[1]=max(i[1],last[1])
       else:
         r.append(i)
    return r

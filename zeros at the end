class Solution:
    def rotation(self,num):
        n=len(num)
        s=[]
        r=[]
        for i in range(n):
            if num[i]==0:
                s.append(num[i])
        for i in range(n):
            if num[i]!=0:
                r.append(num[i])
        return r+s

def merge(intervals):
    intervals.sort()
    
    result = []
    
    for i in intervals:
        if result == []:
            result.append(i)
        else:
            last = result[-1]
            
            # check overlap
            if i[0] <= last[1]:
                last[1] = max(last[1], i[1])
            else:
                result.append(i)
    
    return result


# Example
intervals = [[1,3], [2,6], [8,10], [15,18]]
print(merge(intervals))
